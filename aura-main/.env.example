# Environment Configuration for Advanced RAG System

# LLM API Keys (Required for query enhancement)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# LLM Provider Selection
LLM_PROVIDER=anthropic  # Options: 'anthropic' or 'openai'

# Embedding and Reranking Models
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Hybrid Search Configuration
HYBRID_ALPHA=0.7  # 0.7 = 70% vector search, 30% BM25 keyword search
BM25_ENABLED=true

# Chunking Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50
USE_HIERARCHICAL_CHUNKING=true

# Query Enhancement
ENABLE_QUERY_ENHANCEMENT=true
MULTI_QUERY_COUNT=3

# Reranking Configuration
ENABLE_RERANKING=true
RERANKING_FUSION_WEIGHT=0.7
# SCORE_THRESHOLD=0.5  # Optional: Minimum relevance score

# Search Defaults
DEFAULT_TOP_K=5
DEFAULT_STRATEGY=multi_query  # Options: multi_query, decompose, hyde, standard
INCLUDE_CONTEXT=true

# Index Configuration
RAG_INDEX_DIR=rag/indices
USE_HNSW=true
HNSW_THRESHOLD=1000

# File Processing
SUPPORTED_EXTENSIONS=[".py",".js",".ts",".java"]
EXCLUDE_DIRS=["venv","node_modules","__pycache__",".git","dist","build"]

# Performance
BATCH_SIZE=32
MAX_WORKERS=4

# Application Configuration
APP_NAME=Aura - Advanced RAG System
APP_VERSION=2.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000
RELOAD=false

# Logging
LOG_LEVEL=INFO
# LOG_FILE=logs/aura.log

# Storage
UPLOAD_DIR=uploads
EXTRACTED_DIR=extracted
REPORTS_DIR=reports
